# ── WeeeR Feature Flags — D84/D-2 ────────────────────────────────────────────
# ฟีเจอร์เปิด/ปิด per module
# D-1: ทุกตัว false (ใช้ localStorage)
# D-2: เปิดทีละ module เมื่อ backend API พร้อม

NEXT_PUBLIC_USE_API_AUTH=false
NEXT_PUBLIC_USE_API_POINTS=false
NEXT_PUBLIC_USE_API_OFFER=false
NEXT_PUBLIC_USE_API_REPAIR=false
NEXT_PUBLIC_USE_API_MAINTAIN=false
NEXT_PUBLIC_USE_API_PARTS=false
NEXT_PUBLIC_USE_API_SCRAP=false
NEXT_PUBLIC_USE_API_RESELL=false

# ── API Base URL ──────────────────────────────────────────────────────────────
# Backend API base URL (ไม่ใส่ trailing slash)
# Dev: ชี้ไป local backend server
# Prod: ชี้ไป production API
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── WebSocket (D-2 parts-sync) — @needs-backend-sync ─────────────────────────
# เปิดใช้เมื่อ Backend Sub-CMD-P1 expose WebSocket endpoint
# NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000

# ── Push Notification (Web Push VAPID) ────────────────────────────────────────
# VAPID public key สำหรับ Web Push subscription
# สร้างด้วย: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
