# .env.local.example — App3R Backend Phase D-1
# Copy to .env.local and fill in values
# ⚠️  DO NOT commit .env.local

# Database (Docker compose: port 5433 to avoid conflict with Python backend on 5432)
DATABASE_URL=postgresql://app3r:app3r@localhost:5433/app3r_dev

# JWT Auth
JWT_SECRET=replace-with-random-32-plus-chars-string-here-app3r-d1

# Token TTL
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# Cookie
COOKIE_DOMAIN=localhost

# Server
PORT=8787
NODE_ENV=development
